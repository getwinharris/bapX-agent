FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install Python packages
RUN pip install --no-cache-dir \
    openai-agents \
    httpx \
    uvicorn \
    fastapi \
    pydantic

# Create agent directory
WORKDIR /agent

# Copy agent runner
COPY docker/agent-runner.py /agent/agent-runner.py

# Port for agent HTTP API
EXPOSE 8765

# Run agent server
CMD ["python", "-u", "/agent/agent-runner.py"]
